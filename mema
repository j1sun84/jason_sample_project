<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My First Website</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f4f4f4;
            color: #333;
        }

        header {
            background: #0077ff;
            color: white;
            text-align: center;
            padding: 20px;
        }

        nav {
            background: #005fcc;
            display: flex;
            justify-content: center;
            gap: 20px;
            padding: 12px;
        }

        nav a {
            color: white;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            text-decoration: underline;
        }

        main {
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        button {
            margin-top: 20px;
            padding: 10px 20px;
            background: #0077ff;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #005fcc;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #222;
            color: white;
            margin-top: 40px;
        }
    </style>
</head>
<body>

<header>
    <h1>My First Website</h1>
    <p>Welcome to my simple webpage!</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Services</a>
    <a href="#">Contact</a>
</nav>

<main>
    <div class="card">
        <h2>Hello, World!</h2>
        <p>
            This is a basic HTML and CSS website. You can customize the colors,
            add more sections, and build it into something amazing.
        </p>

        <button onclick="sayHello()">Click Me</button>
    </div>
</main>

<footer>
    &copy; 2026 My Website. All rights reserved.
</footer>

<script>
function sayHello() {
    alert("Thanks for visiting!");
}
</script>

</body>
</html>
